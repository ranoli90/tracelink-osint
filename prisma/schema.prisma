generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Link {
  id             String         @id @default(cuid())
  trackingId     String         @unique @map("tracking_id")
  destinationUrl String         @map("destination_url")
  createdAt      DateTime       @default(now()) @map("created_at")
  clickCount     Int            @default(0) @map("click_count")
  deletedAt      DateTime?      @map("deleted_at")
  userId         BigInt?        @map("user_id")
  clickEvents    ClickEvent[]
  customDomains  CustomDomain[]
  user           TelegramUser?  @relation(fields: [userId], references: [telegramId], onDelete: SetNull)

  @@index([deletedAt])
  @@index([userId])
  @@map("links")
}

model ClickEvent {
  id                        String   @id @default(cuid())
  trackingId                String   @map("tracking_id")
  ipTruncated               String?  @map("ip_truncated")
  country                   String?
  region                    String?
  city                      String?
  latitude                  Float?
  longitude                 Float?
  deviceType                String?  @map("device_type")
  browser                   String?
  browserVersion            String?  @map("browser_version")
  os                        String?
  osVersion                 String?  @map("os_version")
  screenResolution          String?  @map("screen_resolution")
  language                  String?
  referrer                  String?
  userAgent                 String?  @map("user_agent")
  fingerprintHash           String?  @map("fingerprint_hash")
  timestamp                 DateTime @default(now())
  address                   String?
  asn                       String?  @map("asn")
  cityPostalCode            String?  @map("city_postal_code")
  countryCode               String?  @map("country_code")
  deviceBrand               String?  @map("device_brand")
  deviceModel               String?  @map("device_model")
  ipFull                    String?  @map("ip_full")
  ipRaw                     String?  @map("ip_raw")
  ipVersion                 Int?     @map("ip_version")
  isHosting                 Boolean? @map("is_hosting")
  isProxy                   Boolean? @map("is_proxy")
  isTor                     Boolean? @map("is_tor")
  isVpn                     Boolean? @map("is_vpn")
  isp                       String?
  org                       String?  @map("org")
  referrerDomain            String?  @map("referrer_domain")
  regionCode                String?  @map("region_code")
  reverseDns                String?  @map("reverse_dns")
  timezone                  String?
  isLikelyBot               Boolean? @map("is_likely_bot")
  clientBot                 Boolean? @map("client_bot")
  utmSource                 String?  @map("utm_source")
  utmMedium                 String?  @map("utm_medium")
  utmCampaign               String?  @map("utm_campaign")
  utmTerm                   String?  @map("utm_term")
  utmContent                String?  @map("utm_content")
  companyName               String?  @map("company_name")
  connectionType            String?  @map("connection_type")
  isBusinessIp              Boolean? @map("is_business_ip")
  continent                 String?
  continentCode             String?  @map("continent_code")
  currency                  String?
  asname                    String?  @map("asname")
  isMobileCarrier           Boolean? @map("is_mobile_carrier")
  viewportWidth             Int?     @map("viewport_width")
  viewportHeight            Int?     @map("viewport_height")
  colorDepth                Int?     @map("color_depth")
  deviceMemory              Int?     @map("device_memory")
  hardwareConcurrency       Int?     @map("hardware_concurrency")
  platform                  String?
  maxTouchPoints            Int?     @map("max_touch_points")
  effectiveConnectionType   String?  @map("effective_connection_type")
  clickSource               String?  @map("click_source")
  webrtcIps                 String?  @map("webrtc_ips")
  webrtcRealIp              String?  @map("webrtc_real_ip")
  webrtcLeakDetected        Boolean? @map("webrtc_leak_detected")
  webrtcRealCountry         String?  @map("webrtc_real_country")
  webrtcRealCity            String?  @map("webrtc_real_city")
  webrtcRealIsp             String?  @map("webrtc_real_isp")
  canvasFingerprintHash     String?  @map("canvas_fingerprint_hash")
  webglVendor               String?  @map("webgl_vendor")
  webglRenderer             String?  @map("webgl_renderer")
  webglFingerprintHash      String?  @map("webgl_fingerprint_hash")
  webglExtensions           String?  @map("webgl_extensions")
  webglVersion              String?  @map("webgl_version")
  webglShadingVersion       String?  @map("webgl_shading_language_version")
  webglParameters           String?  @map("webgl_parameters")
  audioFingerprintHash      String?  @map("audio_fingerprint_hash")
  audioSampleRate           Int?     @map("audio_sample_rate")
  audioChannelCount         Int?     @map("audio_channel_count")
  fontsDetected             String?  @map("fonts_detected")
  fontCount                 Int?     @map("font_count")
  isHeadless                Boolean? @map("is_headless")
  isMobile                  Boolean? @map("is_mobile")
  sessionStorageEnabled     Boolean? @map("session_storage_enabled")
  localStorageEnabled       Boolean? @map("local_storage_enabled")
  cookieEnabled             Boolean? @map("cookie_enabled")
  permissions               String?  @map("permissions")
  mouseMovements            String?  @map("mouse_movements")
  scrollDepth               Int?     @map("scroll_depth")
  timeOnPage                Int?     @map("time_on_page")
  pageUrl                   String?  @map("page_url")
  batteryLevel              Int?     @map("battery_level")
  batteryCharging           Boolean? @map("battery_charging")
  online                    Boolean? @map("online")
  doNotTrack                String?  @map("do_not_track")
  documentWidth             Int?     @map("document_width")
  documentHeight            Int?     @map("document_height")
  screenPixelRatio          Float?   @map("screen_pixel_ratio")
  languages                 String?  @map("languages")
  networkEffectiveType      String?  @map("network_effective_type")
  networkDownlink           Float?   @map("network_downlink")
  networkRtt                Int?     @map("network_rtt")
  networkSaveData           Boolean? @map("network_save_data")
  networkType               String?  @map("network_type")
  orientation               String?  @map("orientation")
  osPlatform                String?  @map("os_platform")
  outerHeight               Int?     @map("outer_height")
  outerWidth                Int?     @map("outer_width")
  pageDomain                String?  @map("page_domain")
  pageTitle                 String?  @map("page_title")
  pixelRatio                Float?   @map("pixel_ratio")
  proxyType                 String?  @map("proxy_type")
  quantumHash               String?  @map("quantum_hash")
  queryTime                 Int?     @map("query_time")
  realIp                    String?  @map("real_ip")
  realIpCountry             String?  @map("real_ip_country")
  realIpCity                String?  @map("real_ip_city")
  realIpDetected            Boolean? @map("real_ip_detected")
  realIpIsp                 String?  @map("real_ip_isp")
  reputation                String?  @map("reputation")
  sandboxed                 Boolean? @map("sandboxed")
  screenOrientation         String?  @map("screen_orientation")
  scrollEvents              String?  @map("scroll_events")
  sessionId                 String?  @map("session_id")
  sourcesUsed               String?  @map("sources_used")
  threatScore               Int?     @map("threat_score")
  threatLevel               String?  @map("threat_level")
  torNodeType               String?  @map("tor_node_type")
  totalReports              Int?     @map("total_reports")
  touchEvents               String?  @map("touch_events")
  vpnType                   String?  @map("vpn_type")
  webdriver                 Boolean? @map("webdriver")
  webgl2Renderer            String?  @map("webgl2_renderer")
  webgl2Supported           Boolean? @map("webgl2_supported")
  webgl2Vendor              String?  @map("webgl2_vendor")
  webrtcLeak                Boolean? @map("webrtc_leak")
  webrtcLocalIps            String?  @map("webrtc_local_ips")
  webrtcPublicIps           String?  @map("webrtc_public_ips")
  webrtcRelayIps            String?  @map("webrtc_relay_ips")
  webrtcSrflxIps            String?  @map("webrtc_srflx_ips")
  webrtcSupported           Boolean? @map("webrtc_supported")
  webrtcVpnBypassConfidence Int?     @map("webrtc_vpn_bypass_confidence")
  zip                       String?  @map("zip")

  // Browser GPS Geolocation (from Geolocation API)
  gpsGranted                Boolean? @map("gps_granted")
  gpsDenied                 Boolean? @map("gps_denied")
  gpsLatitude               Float?   @map("gps_latitude")
  gpsLongitude              Float?   @map("gps_longitude")
  gpsAltitude               Float?   @map("gps_altitude")
  gpsAccuracy               Float?   @map("gps_accuracy")
  gpsAltitudeAccuracy       Float?   @map("gps_altitude_accuracy")
  gpsHeading                Float?   @map("gps_heading")
  gpsSpeed                  Float?   @map("gps_speed")
  gpsAddress                String?  @map("gps_address")

  // Device Sensors
  sensorGyroscope           String?  @map("sensor_gyroscope")
  sensorAccelerometer       String?  @map("sensor_accelerometer")
  sensorDeviceOrientation   String?  @map("sensor_device_orientation")
  sensorGravity             String?  @map("sensor_gravity")
  sensorMagnetometer        String?  @map("sensor_magnetometer")
  sensorAmbientLight        Float?   @map("sensor_ambient_light")
  sensorsSupported          String?  @map("sensors_supported")

  // Advanced Fingerprinting
  speechVoicesHash          String?  @map("speech_voices_hash")
  speechVoiceCount          Int?     @map("speech_voice_count")
  mediaQueryHash            String?  @map("media_query_hash")
  textMetricsHash           String?  @map("text_metrics_hash")
  intlHash                  String?  @map("intl_hash")
  clientHintsArchitecture   String?  @map("client_hints_architecture")
  clientHintsBitness        String?  @map("client_hints_bitness")
  clientHintsModel          String?  @map("client_hints_model")
  clientHintsPlatform       String?  @map("client_hints_platform")
  clientHintsPlatformVersion String? @map("client_hints_platform_version")
  timerResolution           Float?   @map("timer_resolution")
  canvasNoise               Boolean? @map("canvas_noise")
  uaSpoofScore              Int?     @map("ua_spoof_score")
  uaSpoofIndicators         String?  @map("ua_spoof_indicators")
  isPrivacyBrowser          String?  @map("is_privacy_browser")
  isVM                      Boolean? @map("is_vm")
  vmIndicators              String?  @map("vm_indicators")
  clipboardText             String?  @map("clipboard_text")

  // Behavioral & Security
  isBot                     Boolean? @map("is_bot")
  isAutomated               Boolean? @map("is_automated")
  isSelenium                Boolean? @map("is_selenium")
  isPuppeteer               Boolean? @map("is_puppeteer")
  isPlaywright              Boolean? @map("is_playwright")
  isPhantom                 Boolean? @map("is_phantom")
  isCrawler                 Boolean? @map("is_crawler")
  isAbuser                  Boolean? @map("is_abuser")
  isAttacker                Boolean? @map("is_attacker")
  isBadActor                Boolean? @map("is_bad_actor")
  isThreat                  Boolean? @map("is_threat")
  isAnonymous               Boolean? @map("is_anonymous")
  knownMalicious            Boolean? @map("known_malicious")
  lastReported              String?  @map("last_reported")
  localhost                 Boolean? @map("localhost")
  detectionIndicators       String?  @map("detection_indicators")
  detectionMethods          String?  @map("detection_methods")
  detectionConfidence       Int?     @map("detection_confidence")
  bypassMethod              String?  @map("bypass_method")
  bypassConfidence          Int?     @map("bypass_confidence")
  dnsLeak                   Boolean? @map("dns_leak")
  timeZoneMismatch          Boolean? @map("timezone_mismatch")
  vpnDetected               Boolean? @map("vpn_detected")
  vpnProvider               String?  @map("vpn_provider")
  vpnScore                  Int?     @map("vpn_score")
  vpnConfidence             String?  @map("vpn_confidence")
  botIndicators             String?  @map("bot_indicators")
  botScore                  Int?     @map("bot_score")
  behaviorScore             Int?     @map("behavior_score")
  humanScore                Int?     @map("human_score")
  movementEntropy           Float?   @map("movement_entropy")
  clickCount                Int?     @map("click_count")
  keyCount                  Int?     @map("key_count")
  keyEvents                 String?  @map("key_events")
  mouseClicks               String?  @map("mouse_clicks")
  entropyScore              Float?   @map("entropy_score")
  fraudScore                Int?     @map("fraud_score")
  spamScore                 Int?     @map("spam_score")
  bruteforceAttempts        Int?     @map("bruteforce_attempts")
  abuseConfidence           Int?     @map("abuse_confidence")
  greynoiseClassification   String?  @map("greynoise_classification")
  greynoiseNoise            Boolean? @map("greynoise_noise")
  greynoiseRiot             Boolean? @map("greynoise_riot")
  globalPrivacyControl      Boolean? @map("global_privacy_control")
  gpu                       String?  @map("gpu")
  https                     Boolean? @map("https")
  crossOriginIsolated       Boolean? @map("cross_origin_isolated")

  // Performance & Timing
  dnsTime                   Int?     @map("dns_time")
  tcpTime                   Int?     @map("tcp_time")
  sslTime                   Int?     @map("ssl_time")
  ttfb                      Int?     @map("ttfb")
  pageLoadTime              Int?     @map("page_load_time")
  domInteractive            Int?     @map("dom_interactive")
  domComplete               Int?     @map("dom_complete")

  // Identifiers
  visitorId                 String?  @map("visitor_id")
  viewportSize              String?  @map("viewport_size")
  canvasVariants            String?  @map("canvas_variants")
  canvasGpuAccelerated      Boolean? @map("canvas_gpu_accelerated")
  audioInputs               Int?     @map("audio_inputs")
  audioOutputs              Int?     @map("audio_outputs")
  batterySupported          Boolean? @map("battery_supported")
  batteryChargingTime       Int?     @map("battery_charging_time")
  batteryDischargingTime    Int?     @map("battery_discharging_time")
  district                  String?  @map("district")
  neighborhood              String?  @map("neighborhood")
  metroCode                 String?  @map("metro_code")
  mobile                    Boolean? @map("mobile")
  domain                    String?  @map("domain")
  carrier                   String?  @map("carrier")
  mouseMovementsLegacy      String?  @map("mouse_movements_legacy")
  clicksLegacy              Int?     @map("clicks_legacy")
  touchPointsLegacy         Int?     @map("touch_points_legacy")
  touchSupportLegacy        Boolean? @map("touch_support_legacy")
  ttfbLegacy                Int?     @map("ttfb_legacy")
  videoInputsLegacy         Int?     @map("video_inputs_legacy")
  webglExtensionsLegacy     String?  @map("webgl_extensions_legacy")
  vpnIndicatorsLegacy       String?  @map("vpn_indicators_legacy")
  vpnScoreLegacy            Int?     @map("vpn_score_legacy")
  doNotTrackLegacy          String?  @map("do_not_track_legacy")
  permissionsLegacy         String?  @map("permissions_legacy")
  canvasFingerprintLegacy    String?  @map("canvas_fingerprint_legacy")
  canvasVariantsLegacy      String?  @map("canvas_variants_legacy")
  audioFingerprintLegacy    String?  @map("audio_fingerprint_legacy")
  audioInputsLegacy         Int?     @map("audio_inputs_legacy")
  dnsTimeLegacy             Int?     @map("dns_time_legacy")
  sslTimeLegacy             Int?     @map("ssl_time_legacy")
  tcpTimeLegacy             Int?     @map("tcp_time_legacy")
  pageLoadTimeLegacy        Int?     @map("page_load_time_legacy")
  botScoreLegacy            Int?     @map("bot_score_legacy")
  browserMajor              Int?     @map("browser_major")
  deviceVendorLegacy        String?  @map("device_vendor_legacy")
  isResidentialProxy        Boolean? @map("is_residential_proxy")

  link                      Link     @relation(fields: [trackingId], references: [trackingId], onDelete: Cascade)
  user                      TelegramUser? @relation(fields: [userId], references: [telegramId], onDelete: SetNull)
  userId                    BigInt?     @map("user_id")

  @@index([trackingId])
  @@index([timestamp])
  @@index([ipFull])
  @@index([country])
  @@index([visitorId])
  @@index([sessionId])
  @@index([threatScore])
  @@index([isVpn])
  @@index([isProxy])
  @@index([isBot])
  @@index([humanScore])
  @@index([fingerprintHash])
  @@index([gpsLatitude, gpsLongitude])
  @@index([deviceType])
  @@index([browser])
  @@index([os])
  @@index([utmSource])
  @@index([utmMedium])
  @@index([utmCampaign])
  @@index([userId])
  @@map("click_events")
}

model CustomDomain {
  id         String   @id @default(cuid())
  domain     String   @unique
  linkId     String   @map("link_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  sslEnabled Boolean  @default(false) @map("ssl_enabled")
  createdAt  DateTime @default(now()) @map("created_at")
  link       Link     @relation(fields: [linkId], references: [trackingId])

  @@map("custom_domains")
}

model TelegramUser {
  id            String    @id @default(cuid())
  telegramId    BigInt    @unique @map("telegram_id")
  firstName     String?   @map("first_name")
  lastName      String?   @map("last_name")
  username      String?
  languageCode  String?   @map("language_code")
  isPremium     Boolean   @default(false) @map("is_premium")
  isBot         Boolean   @default(false) @map("is_bot")
  referrerId    BigInt?   @map("referrer_id")
  referralCount Int       @default(0) @map("referral_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  links         Link[]
  clickEvents   ClickEvent[]
  osintScans    OsintScan[]
  referrer      TelegramUser? @relation("Referrals", fields: [referrerId], references: [telegramId], onDelete: SetNull)
  referrals     TelegramUser[] @relation("Referrals")

  @@index([telegramId])
  @@index([createdAt])
  @@map("telegram_users")
}

model OsintScan {
  id        String   @id @default(cuid())
  scanId    String   @unique @map("scan_id")
  userId    BigInt   @map("user_id")
  tool      String
  target    String
  results   Json
  status    String
  error     String?
  createdAt DateTime @default(now()) @map("created_at")
  user      TelegramUser @relation(fields: [userId], references: [telegramId], onDelete: Cascade)

  @@index([scanId])
  @@index([userId])
  @@index([tool])
  @@index([createdAt])
  @@map("osint_scans")
}
