# TraceLink OSINT Environment Configuration
# Render.com Deployment Template
# Copy this to .env and fill in your values

# ===== REQUIRED CONFIGURATION =====

# Telegram Bot Configuration
BOT_TOKEN=8692641453:AAGZa2cgGbVw2-IZN2ivV4xLhIgFkoc2Chg
ADMIN_TELEGRAM_IDS=your_admin_telegram_id

# Application URLs
WEBAPP_URL=https://your-app.onrender.com
BASE_URL=https://api.tracelink.io
API_URL=https://api.tracelink.io

# Database (will be auto-configured by Render)
# DATABASE_URL=postgresql://user:password@host:5432/db

# Redis (will be auto-configured by Render)
# REDIS_URL=redis://host:6379

# ===== OPTIONAL API KEYS =====

# OSINT Tools
SHODAN_API_KEY=your_shodan_api_key
HUNTER_API_KEY=your_hunter_api_key
HIBP_API_KEY=your_hibp_api_key
DEHASHED_API_KEY=your_dehashed_api_key
BREACHDIRECTORY_API_KEY=your_breachdirectory_api_key
ABUSEIPDB_API_KEY=your_abuseipdb_api_key
ALIENVAULT_API_KEY=your_alienvault_api_key

# AI/Ollama Configuration
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2

# Tor/Dark Web
TOR_PROXY=socks5://tor:9050

# ===== NODE CONFIGURATION =====
NODE_ENV=production
PORT=3000

# ===== SECURITY =====
SESSION_SECRET=your_session_secret_min_32_chars
CSRF_SECRET=your_csrf_secret_min_32_chars

# ===== OPTIONAL FEATURES =====

# Analytics (optional)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Email (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Custom Domain (optional)
# CUSTOM_DOMAIN=tracelink.io
