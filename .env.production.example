# Production Environment Variables
# Copy to .env and configure for Netlify deployment

NODE_ENV=production

# Base URL for short links (use your custom domain)
BASE_URL=https://thr0ne.com
# Porkbun API keys (porkbun.com/account/api) - for auto DNS when adding custom domains
PORKBUN_API_KEY=
PORKBUN_SECRET_API_KEY=
PORKBUN_ROOT_DOMAIN=thr0ne.com
NETLIFY_DNS_TARGET=apex-loadbalancer.netlify.com

# IMPORTANT: Change these to secure values!
# Use a strong password (at least 16 characters, mix of letters, numbers, symbols)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# Port (usually 3000 for Node.js)
PORT=3000

# Neon PostgreSQL connection string
# Get this from your Neon dashboard: https://console.neon.tech
DATABASE_URL="postgresql://username:password@host.neon.tech/dbname?sslmode=require"

# Optional: Enable automatic IP database updates (may increase cold start times)
IP_DB_AUTO_UPDATE=false
