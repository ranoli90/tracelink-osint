# Copy to .env and fill in. For Netlify, set these in Site settings → Environment variables.
NODE_ENV=development
BASE_URL=https://thr0ne.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
PORT=3000
# PostgreSQL connection string (required for run and for Netlify build/migrate)
DATABASE_URL="postgresql://user:password@localhost:5432/tracelink?schema=public"
# Porkbun API (for DNS when adding custom domains) - get keys at porkbun.com/account/api
PORKBUN_API_KEY=
PORKBUN_SECRET_API_KEY=
# Root domain for Porkbun DNS (e.g. thr0ne.com)
PORKBUN_ROOT_DOMAIN=thr0ne.com
# Netlify target for CNAME (subdomains point here)
NETLIFY_DNS_TARGET=apex-loadbalancer.netlify.com
# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
# Comma-separated list of admin Telegram IDs (e.g., "123456789,987654321")
ADMIN_TELEGRAM_IDS=
# Web App URL for Telegram Mini App (e.g., https://your-app.netlify.app)
WEBAPP_URL=https://your-app.netlify.app
# HMAC secret for validating initData (generate with: openssl rand -hex 32)
HMAC_SECRET=your_hmac_secret_here
