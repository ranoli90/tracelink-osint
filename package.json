{
  "name": "tracelink",
  "version": "1.0.0",
  "description": "Privacy-compliant link tracking and fingerprinting tool",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "npx prisma generate && npx prisma migrate deploy",
    "deploy": "netlify deploy --prod --build",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "node scripts/seed.js",
    "db:studio": "npx prisma studio",
    "db:download": "node scripts/download-db.js",
    "setup:dns": "node scripts/setup-thr0ne-dns.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
  },
  "dependencies": {
    "@ip-location-db/dbip-city": "^2.3.2025010119",
    "@ip-location-db/geo-whois-asn-country": "^2.3.2026022319",
    "@prisma/client": "^5.22.0",
    "@twa-dev/sdk": "^7.10.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csrf": "^3.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.1",
    "helmet": "^7.1.0",
    "ipwhois": "^1.0.3",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.8",
    "node-html-parser": "^7.1.0",
    "redis": "^4.6.13",
    "serverless-http": "^3.2.0",
    "telegraf": "^4.16.3",
    "ua-parser-js": "^2.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "acorn": "^8.16.0",
    "jest": "^29.7.0",
    "netlify-cli": "^17.0.0",
    "prisma": "^5.22.0",
    "puppeteer": "^24.37.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}